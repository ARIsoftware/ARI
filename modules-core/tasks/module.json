{
  "id": "tasks",
  "name": "Tasks",
  "title": "Todo",
  "description": "Task management with priority radar, analytics, and focus timer",
  "version": "1.0.0",
  "author": "ARI Team",
  "icon": "CheckSquare",
  "enabled": true,
  "fullscreen": false,
  "menuPriority": 2,
  "permissions": {
    "database": true,
    "api": true,
    "dashboard": true
  },
  "routes": [
    {
      "path": "/tasks",
      "label": "All Tasks",
      "icon": "CheckSquare",
      "sidebarPosition": "main"
    },
    {
      "path": "/add-task",
      "label": "Add Task",
      "icon": "Plus",
      "sidebarPosition": "main"
    },
    {
      "path": "/radar",
      "label": "Task Radar",
      "icon": "Radar",
      "sidebarPosition": "main"
    }
  ],
  "database": {
    "tables": ["tasks"],
    "migrations": "./database/migrations"
  },
  "dashboard": {
    "widgets": true,
    "widgetComponents": ["./components/widget.tsx"]
  }
}
