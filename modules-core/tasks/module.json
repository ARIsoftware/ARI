{
  "id": "tasks",
  "name": "Tasks",
  "group": "Todo",
  "description": "Task management with priority radar, analytics, and focus timer",
  "version": "1.0.0",
  "author": "ARI Team",
  "icon": "CheckSquare",
  "enabled": true,
  "fullscreen": false,
  "menuPriority": 2,
  "permissions": {
    "database": true,
    "api": true,
    "dashboard": true
  },
  "routes": [
    {
      "path": "/tasks",
      "label": "All Tasks",
      "icon": "CheckSquare",
      "sidebarPosition": "main"
    },
    {
      "path": "/tasks/add",
      "label": "Add Task",
      "icon": "Plus",
      "sidebarPosition": "none"
    },
    {
      "path": "/tasks/radar",
      "label": "Task Radar",
      "icon": "Radar",
      "sidebarPosition": "none"
    },
    {
      "path": "/tasks/edit",
      "label": "Edit Task",
      "icon": "Pencil",
      "sidebarPosition": "none"
    }
  ],
  "globalProvider": {
    "component": "./components/quick-add-task-sheet.tsx",
    "exportName": "QuickAddTaskProvider"
  },
  "database": {
    "tables": ["tasks"]
  },
  "dashboard": {
    "widgets": true,
    "statCards": ["./components/dashboard-stat-card.tsx"],
    "widgetComponents": [
      "./components/dashboard-activity-widget.tsx",
      "./components/dashboard-radar-widget.tsx"
    ]
  }
}
