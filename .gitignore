# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear on external volumes
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Markdown Reports
*-report.md

# Security audits and migration plans
*AUDIT*.md
*RLS_MIGRATION*.md
*_MIGRATION.md
*_MIGRATION_*.md
FIX_PLAN.md

# IDE/Editor
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# Testing/Coverage
/coverage/
.nyc_output/
*.lcov

# dependencies
/node_modules
package-lock.json

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (but allow .env.example for documentation)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# clerk configuration (can include secrets)
/.clerk/

# database dumps (but allow migrations, module schemas, and setup)
*.sql
!/migrations/*.sql
!**/database/*.sql
!/lib/db/setup.sql

# Private directory (folder tracked, contents ignored)
/private/*
!/private/.gitkeep

# Drizzle generated migrations (we use lib/db/schema/ instead)
lib/db/migrations/

# Turbo
.turbo/

# Cache
.cache/
*.cache

# Logs
logs/
*.log
!.gitkeep

# Temp files
*.tmp
*.temp
*.bak

# Sentry
.sentryclirc

# PWA generated
/public/sw.js
/public/workbox-*.js

# Local testing
/playwright-report/
/playwright/.cache/
/test-results/

# Claude Code
.claude/worktrees/

# Auto-generated module registry files
lib/generated/
preflight.yml

# pnpm workspace config (local security hardening)
pnpm-workspace.yaml
