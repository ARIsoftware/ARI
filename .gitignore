Icon

# Thumbnails
._*


# Markdown Reports
*-report.md


# Files that might appear on external volumes
.Spotlight-V100
.Trashes

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# auto-generated module registry
/lib/generated/

# clerk configuration (can include secrets)
/.clerk/

# database dumps
*.sql
