# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# macOS
.DS_Store

# Icon must end with two \r
Icon

# Thumbnails
._*


# Markdown Reports
*-report.md


# Files that might appear on external volumes
.Spotlight-V100
.Trashes

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (but allow .env.example for documentation)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# auto-generated module registry
/lib/generated/

# clerk configuration (can include secrets)
/.clerk/

# database dumps (but allow migrations folder)
*.sql
!/migrations/*.sql

# Drizzle generated migrations (we use lib/db/schema/ instead)
lib/db/migrations/
